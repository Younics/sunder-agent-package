<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Sunder.Package.Agent.Subagents.PackageViews"
              xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
             x:Class="Sunder.Package.Agent.Subagents.PackageViews.SubsessionsView"
             x:DataType="vm:SubsessionsViewModel"
             mc:Ignorable="d">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://LiveMarkdown.Avalonia/Defaults.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>
    <StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml" />

    <Style Selector="Border.subsession-shell">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.subsession-pane">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
    </Style>

    <Style Selector="Border.subsession-list-pane">
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>

    <Style Selector="Border.subsession-pane-header">
      <Setter Property="Padding" Value="28,24,28,18" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.subsession-list-body">
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="Border.subsession-detail-body">
      <Setter Property="Padding" Value="28,24" />
    </Style>

    <Style Selector="Border.subsession-actions">
      <Setter Property="Padding" Value="18" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style Selector="TextBlock.subsession-title">
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    </Style>

    <Style Selector="TextBlock.subsession-caption">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="ListBox.subsession-list">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.subsession-list ListBoxItem">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Base}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="ListBox.subsession-list ListBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Strong}" />
    </Style>

    <Style Selector="ListBox.subsession-list ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Info.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Accent}" />
    </Style>

    <Style Selector="Button.subsession-open-action">
      <Setter Property="Width" Value="32" />
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.subsession-open-action:pointerover">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Accent}" />
    </Style>

    <Style Selector="Border.message-avatar">
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="42" />
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Strong}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    </Style>

    <Style Selector="TextBlock.avatar-glyph">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
    </Style>

    <Style Selector="TextBlock.thinking-text">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Regular" />
      <Setter Property="Opacity" Value="0.72" />
      <Style.Animations>
        <Animation Duration="0:0:1.4"
                   IterationCount="INFINITE"
                   PlaybackDirection="Alternate">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0.52" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0.88" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="Border.message-bubble">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Base}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style Selector="Border.message-bubble.user">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Info.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Accent}" />
    </Style>

    <Style Selector="Border.timeline-spine">
      <Setter Property="Width" Value="1" />
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.tool-step-header">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Code}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Border.tool-state-dot">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Full}" />
    </Style>

    <Style Selector="TextBlock.tool-state-icon">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBlock.tool-label">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
      <Setter Property="FontSize" Value="14" />
    </Style>

    <Style Selector="TextBlock.tool-command">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontFamily" Value="Menlo,Consolas,monospace" />
    </Style>

    <Style Selector="TextBlock.tool-chevron">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <UserControl.DataTemplates>
    <DataTemplate x:DataType="vm:SubsessionActivityTranscriptRowViewModel">
      <Grid ColumnDefinitions="42,*"
            ColumnSpacing="16"
            Margin="0,0,0,22"
            HorizontalAlignment="Stretch">
        <Border Classes="message-avatar"
                VerticalAlignment="Top">
          <TextBlock Classes="avatar-glyph"
                     Text="{Binding RoleGlyph}" />
        </Border>

        <TextBlock Grid.Column="1"
                   Classes="thinking-text"
                   Text="{Binding ThinkingText}"
                   VerticalAlignment="Center" />
      </Grid>
    </DataTemplate>

    <DataTemplate x:DataType="vm:SubsessionTextTranscriptRowViewModel">
      <Grid Margin="0,0,0,30"
            HorizontalAlignment="Stretch">
        <Grid ColumnDefinitions="42,*"
              ColumnSpacing="16"
              HorizontalAlignment="Stretch"
              IsVisible="{Binding IsNotUser}">
          <Border Classes="message-avatar"
                  VerticalAlignment="Top">
            <TextBlock Classes="avatar-glyph"
                       Text="{Binding RoleGlyph}" />
          </Border>
          <Border Grid.Column="1"
                  Classes="message-bubble">
            <md:MarkdownRenderer MarkdownBuilder="{Binding MarkdownBuilder}" />
          </Border>
        </Grid>
        <Grid ColumnDefinitions="*"
              HorizontalAlignment="Stretch"
              IsVisible="{Binding IsUser}">
          <Border Classes="message-bubble user">
            <md:MarkdownRenderer MarkdownBuilder="{Binding MarkdownBuilder}" />
          </Border>
        </Grid>
      </Grid>
    </DataTemplate>

    <DataTemplate x:DataType="vm:SubsessionToolInvocationRowViewModel">
      <Grid ColumnDefinitions="42,*"
            ColumnSpacing="16"
            Margin="0,0,0,20"
            HorizontalAlignment="Stretch">
        <Border Classes="timeline-spine"
                Margin="0,-22,0,-6" />
        <StackPanel Grid.Column="1"
                    HorizontalAlignment="Stretch">
          <Button Classes="tool-step-header"
                  Command="{Binding ToggleExpandedCommand}">
            <Grid RowDefinitions="Auto,Auto"
                  ColumnDefinitions="Auto,*,Auto"
                  RowSpacing="3"
                  ColumnSpacing="8"
                  HorizontalAlignment="Stretch">
              <Border Grid.Row="0"
                      Grid.Column="0"
                      Classes="tool-state-dot"
                      Background="{Binding StateSoftBrush}"
                      BorderBrush="{Binding StateBrush}">
                <TextBlock Classes="tool-state-icon"
                           Text="{Binding StatusIconText}"
                           Foreground="{Binding StateBrush}" />
              </Border>
              <TextBlock Grid.Row="0"
                         Grid.Column="1"
                         Classes="tool-label"
                         Text="{Binding ToolLabel}"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Row="0"
                         Grid.Column="2"
                         Classes="tool-chevron"
                         Text="{Binding ExpandGlyph}" />
              <TextBlock Grid.Row="1"
                          Grid.Column="1"
                          Classes="tool-command"
                          Text="{Binding HeaderDetailText}"
                          TextWrapping="Wrap"
                          MaxLines="2"
                          TextTrimming="CharacterEllipsis"
                          Margin="0,-1,8,0"
                          IsVisible="{Binding HasHeaderDetail}" />
            </Grid>
          </Button>

          <ItemsControl ItemsSource="{Binding ChildSessionLinks}"
                        IsVisible="{Binding HasChildSessionLinks}"
                        Margin="28,8,0,0">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SubsessionChildSessionLinkViewModel">
                <Button Classes="secondary-action compact-action"
                        Margin="0,0,8,8"
                        Command="{Binding $parent[UserControl].DataContext.OpenChildSessionCommand}"
                        CommandParameter="{Binding}">
                  <StackPanel Orientation="Horizontal"
                              Spacing="8">
                    <Border Classes="tool-state-dot"
                            Background="{Binding StateSoftBrush}"
                            BorderBrush="{Binding StateBrush}"
                            ToolTip.Tip="{Binding StatusText}">
                      <TextBlock Classes="tool-state-icon"
                                 Text="{Binding StatusIconText}"
                                 Foreground="{Binding StateBrush}" />
                    </Border>
                    <TextBlock Text="Subsession"
                               Foreground="{DynamicResource Sunder.Brush.Foreground.Muted}" />
                    <TextBlock Text="{Binding DisplayText}" />
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Border Margin="28,10,0,0"
                  Background="{DynamicResource Sunder.Brush.Surface.Popover}"
                  BorderBrush="{DynamicResource Sunder.Brush.Border.Subtle}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource Sunder.Radius.Small}"
                  Padding="16"
                  IsVisible="{Binding ShowDetails}">
            <StackPanel Spacing="12">
              <TextBlock Text="{Binding OutputText}"
                         FontFamily="Menlo,Consolas,monospace"
                         FontSize="13"
                         TextWrapping="Wrap"
                         IsVisible="{Binding HasOutput}" />
              <md:MarkdownRenderer MarkdownBuilder="{Binding DetailMarkdownBuilder}"
                                   IsVisible="{Binding HasMarkdownDetails}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </DataTemplate>
  </UserControl.DataTemplates>

  <Border Classes="subsession-shell">
    <Grid x:Name="SubsessionAdaptiveLayout"
          ColumnDefinitions="360,*"
          ColumnSpacing="4">
      <Border x:Name="SubsessionListPane"
              Classes="subsession-pane subsession-list-pane"
              IsVisible="{Binding ShowListPane}">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0"
                  Classes="subsession-pane-header">
            <StackPanel Spacing="8">
              <TextBlock Classes="subsession-title"
                         Text="Subsessions" />
              <TextBlock Classes="subsession-caption"
                         Text="Review live delegated subagent transcripts." />
            </StackPanel>
          </Border>

          <Border Grid.Row="1"
                  Classes="subsession-list-body">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12">
                <TextBlock Text="No sub-sessions yet."
                           Foreground="{DynamicResource Sunder.Brush.Foreground.Muted}"
                           IsVisible="{Binding HasNoSubsessions}" />
                <ListBox Classes="subsession-list"
                         ItemsSource="{Binding Subsessions}"
                         SelectedItem="{Binding SelectedSubsession, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SubsessionListItemViewModel">
                      <Grid ColumnDefinitions="*,Auto,Auto"
                            ColumnSpacing="10"
                            ToolTip.Tip="{Binding StatusText}">
                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="3"
                              MinWidth="0">
                          <TextBlock Text="{Binding Title}"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Row="1"
                                     Text="{Binding Subtitle}"
                                     Foreground="{DynamicResource Sunder.Brush.Foreground.Muted}"
                                     FontSize="12"
                                     TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding StatusBadgeText}"
                                   Foreground="{Binding StatusBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2"
                                Classes="subsession-open-action"
                                Content=">"
                                Command="{Binding $parent[UserControl].DataContext.OpenSubsessionCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Open transcript" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Grid>
      </Border>

      <Border x:Name="SubsessionDetailPane"
              Grid.Column="1"
              Classes="subsession-pane"
              IsVisible="{Binding ShowDetailPane}">
        <Grid RowDefinitions="Auto,*,Auto">
          <Border Grid.Row="0"
                  Classes="subsession-pane-header">
            <StackPanel Spacing="8">
              <TextBlock Classes="subsession-title"
                         Text="{Binding SelectedSubsession.Title}" />
              <TextBlock Classes="subsession-caption"
                         Text="{Binding SelectedSubsession.Subtitle}" />
            </StackPanel>
          </Border>

          <ScrollViewer x:Name="TranscriptScrollViewer"
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <Border Classes="subsession-detail-body">
              <StackPanel>
                <TextBlock Text="Loading older messages..."
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,18"
                           Foreground="{DynamicResource Sunder.Brush.Foreground.Muted}"
                           IsVisible="{Binding IsLoadingOlderTranscriptRows}" />
                <TextBlock Text="Select a sub-session to inspect its transcript."
                           Foreground="{DynamicResource Sunder.Brush.Foreground.Muted}"
                           IsVisible="{Binding !HasSelectedSubsession}" />
                <TextBlock Text="This sub-session has no transcript messages yet."
                           Foreground="{DynamicResource Sunder.Brush.Foreground.Muted}"
                           IsVisible="{Binding ShowEmptyTranscript}" />
                <ItemsControl ItemsSource="{Binding Messages}"
                              HorizontalAlignment="Stretch" />
              </StackPanel>
            </Border>
          </ScrollViewer>

          <Border Grid.Row="2"
                  Classes="subsession-actions"
                  IsVisible="{Binding IsCompactLayout}">
            <Grid ColumnDefinitions="*,Auto">
              <Button Grid.Column="1"
                      Classes="secondary-action compact-action"
                      Content="Back"
                      Command="{Binding BackToSubsessionsListCommand}"
                      IsVisible="{Binding IsCompactLayout}" />
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
