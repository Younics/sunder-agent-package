<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Sunder.Package.Agent.PackageViews"
             x:Class="Sunder.Package.Agent.PackageViews.AgentPermissionsView"
             x:DataType="vm:AgentPermissionsViewModel"
             mc:Ignorable="d">
  <Grid RowDefinitions="Auto,*,Auto"
        RowSpacing="16">
    <StackPanel Spacing="8">
      <TextBlock Classes="page-title"
                 Text="Permissions" />
      <TextBlock Classes="caption"
                 Text="Packages define actions and request contexts. Choose the default decision for each context."
                 TextWrapping="Wrap" />
    </StackPanel>

    <Border Grid.Row="1"
            Classes="workspace-surface"
            BorderThickness="0"
            CornerRadius="0">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="2*,3*,Auto,Auto"
              ColumnSpacing="12"
              Margin="8,0,8,8">
          <TextBlock Classes="section-title" Text="Action" />
          <TextBlock Grid.Column="1" Classes="section-title" Text="Request Context" />
          <TextBlock Grid.Column="2" Classes="section-title" Text="Package Default" />
          <TextBlock Grid.Column="3" Classes="section-title" Text="Decision" />
        </Grid>
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Rows}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:PermissionBoundaryRowViewModel">
              <Grid ColumnDefinitions="2*,3*,Auto,Auto"
                    ColumnSpacing="12"
                    Margin="0,4">
                <TextBlock Text="{Binding ActionDisplayName}"
                           TextWrapping="Wrap" />
                <StackPanel Grid.Column="1"
                            Spacing="2">
                  <TextBlock Text="{Binding BoundaryDisplayName}"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding BoundaryDescription}"
                             FontSize="11"
                             Opacity="0.7"
                             TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="{Binding DefaultDecision}"
                           VerticalAlignment="Center" />
                <ComboBox Grid.Column="3"
                          ItemsSource="{Binding Decisions}"
                          SelectedItem="{Binding SelectedDecision, Mode=TwoWay}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                Spacing="10">
      <Button Classes="primary-action"
              Content="Save Permissions"
              Command="{Binding SaveCommand}" />
      <Button Classes="secondary-action"
              Content="Reset To Package Defaults"
              Command="{Binding ResetToPackageDefaultsCommand}" />
      <TextBlock Classes="caption"
                 Text="{Binding StatusText}"
                 TextWrapping="Wrap"
                 VerticalAlignment="Center" />
    </StackPanel>
  </Grid>
</UserControl>
