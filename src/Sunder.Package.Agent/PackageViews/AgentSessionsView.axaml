<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Sunder.Package.Agent.PackageViews"
             x:Class="Sunder.Package.Agent.PackageViews.AgentSessionsView"
             x:DataType="vm:AgentSessionsViewModel"
             mc:Ignorable="d">

  <UserControl.Styles>
    <Style Selector="Border.session-shell">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.session-pane">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
    </Style>

    <Style Selector="Border.session-list-pane">
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>

    <Style Selector="Border.session-pane-header">
      <Setter Property="Padding" Value="28,24,28,18" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.session-list-body">
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="Border.session-editor-body">
      <Setter Property="Padding" Value="28,24" />
    </Style>

    <Style Selector="Border.session-actions">
      <Setter Property="Padding" Value="18" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style Selector="Border.session-status-message">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Warning.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Warning}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style Selector="Border.session-status-message.success">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Success.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Success}" />
    </Style>

    <Style Selector="Border.session-status-message.error">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Danger.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Danger}" />
    </Style>

    <Style Selector="TextBlock.session-status-message">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Warning}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.session-status-message.success">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Success}" />
    </Style>

    <Style Selector="TextBlock.session-status-message.error">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Danger}" />
    </Style>

    <Style Selector="TextBlock.session-title">
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    </Style>

    <Style Selector="TextBlock.session-caption">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.session-field-label">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style Selector="ListBox.session-list">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.session-list ListBoxItem">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Base}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="ListBox.session-list ListBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Strong}" />
    </Style>

    <Style Selector="ListBox.session-list ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Info.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Accent}" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    </Style>

    <Style Selector="TextBlock.session-list-meta">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="Button.session-add-action">
      <Setter Property="Width" Value="36" />
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="Regular" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.session-card">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="16" />
    </Style>
  </UserControl.Styles>

  <Border Classes="session-shell">
    <Grid x:Name="SessionAdaptiveLayout"
          ColumnDefinitions="360,*"
          ColumnSpacing="4">
      <Border x:Name="SessionListPane"
              Classes="session-pane session-list-pane"
              IsVisible="{Binding ShowListPane}">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0"
                  Classes="session-pane-header">
            <Grid ColumnDefinitions="*,Auto"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="8">
              <TextBlock Grid.Column="0"
                         Classes="session-title"
                         Text="Sessions"
                         VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Classes="secondary-action compact-action session-add-action"
                      Content="+"
                      Command="{Binding CreateSessionCommand}"
                      ToolTip.Tip="New session" />
              <TextBlock Grid.Row="1"
                         Grid.ColumnSpan="2"
                         Classes="session-caption"
                         Text="Create and manage conversations independently from workspaces." />
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Classes="session-list-body">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12">
                <TextBlock Text="No sessions yet."
                           Foreground="{DynamicResource Sunder.Brush.Foreground.Muted}"
                           IsVisible="{Binding HasNoSessions}" />

                <ListBox Classes="session-list"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:AgentSessionListEntryViewModel">
                      <Grid RowDefinitions="Auto,Auto,Auto"
                            RowSpacing="3"
                            MinWidth="0"
                            Tapped="OnSessionItemTapped">
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1"
                                   Text="{Binding StatusBadgeText}"
                                   Classes="session-list-meta"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding UpdatedText}"
                                   Classes="session-list-meta"
                                   TextTrimming="CharacterEllipsis" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Grid>
      </Border>

      <Border x:Name="SessionEditorPane"
              Grid.Column="1"
              Classes="session-pane"
              IsVisible="{Binding ShowEditorPane}">
        <Grid RowDefinitions="Auto,*,Auto">
          <Border Grid.Row="0"
                  Classes="session-pane-header">
            <StackPanel Spacing="8">
              <TextBlock Classes="session-title"
                         Text="Session" />
              <TextBlock Classes="session-caption"
                         Text="Rename a conversation or delete it with its sub-sessions." />
            </StackPanel>
          </Border>

          <ScrollViewer Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <Border Classes="session-editor-body">
              <StackPanel Spacing="18">
                <Border Classes="session-card">
                  <StackPanel Spacing="14">
                    <StackPanel Spacing="5">
                      <TextBlock Classes="session-field-label"
                                 Text="Title" />
                      <TextBox x:Name="SessionTitleTextBox"
                               Text="{Binding Title, Mode=TwoWay}"
                               PlaceholderText="Session title" />
                    </StackPanel>
                  </StackPanel>
                </Border>

                <Border Classes="session-card">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Details"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Sunder.Brush.Foreground.Primary}" />
                    <TextBlock Text="{Binding DetailStateText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
                    <TextBlock Text="{Binding DetailProfileText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Sunder.Brush.Foreground.Muted}" />
                    <TextBlock Text="{Binding DetailCreatedText}"
                               Foreground="{DynamicResource Sunder.Brush.Foreground.Muted}" />
                    <TextBlock Text="{Binding DetailUpdatedText}"
                               Foreground="{DynamicResource Sunder.Brush.Foreground.Muted}" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </ScrollViewer>

          <Border Grid.Row="2"
                  Classes="session-actions">
            <Grid RowDefinitions="Auto,Auto">
              <Border Grid.Row="0"
                      Classes="session-status-message"
                      Classes.success="{Binding IsStatusSuccess}"
                      Classes.warning="{Binding IsStatusWarning}"
                      Classes.error="{Binding IsStatusError}"
                      IsVisible="{Binding HasStatusText}">
                <TextBlock Classes="session-status-message"
                           Classes.success="{Binding IsStatusSuccess}"
                           Classes.warning="{Binding IsStatusWarning}"
                           Classes.error="{Binding IsStatusError}"
                           Text="{Binding StatusText}" />
              </Border>

              <Grid Grid.Row="1"
                    ColumnDefinitions="Auto,*,Auto,Auto"
                    ColumnSpacing="12">
                <Button Grid.Column="0"
                        Classes="secondary-action compact-action danger-action"
                        Content="Delete Session"
                        Command="{Binding DeleteSessionCommand}" />
                <Button Grid.Column="2"
                        Classes="secondary-action compact-action"
                        Content="Back"
                        Command="{Binding BackToSessionListCommand}"
                        IsVisible="{Binding IsCompactLayout}" />
                <Button Grid.Column="3"
                        Classes="primary-action"
                        Content="Save"
                        Command="{Binding SaveSessionCommand}" />
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
