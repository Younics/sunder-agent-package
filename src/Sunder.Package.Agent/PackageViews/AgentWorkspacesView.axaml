<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Sunder.Package.Agent.PackageViews"
             xmlns:m="using:Sunder.Package.Agent.Contracts.Models"
             x:Class="Sunder.Package.Agent.PackageViews.AgentWorkspacesView"
             x:DataType="vm:AgentWorkspacesViewModel"
             mc:Ignorable="d">

  <UserControl.Styles>
    <Style Selector="Border.workspace-shell">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.workspace-pane">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
    </Style>

    <Style Selector="Border.workspace-list-pane">
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>

    <Style Selector="Border.workspace-pane-header">
      <Setter Property="Padding" Value="28,24,28,18" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.workspace-list-body">
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="Border.workspace-editor-body">
      <Setter Property="Padding" Value="28,24" />
    </Style>

    <Style Selector="Border.workspace-actions">
      <Setter Property="Padding" Value="18" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style Selector="Border.workspace-status-message">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Warning.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Warning}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style Selector="Border.workspace-status-message.success">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Success.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Success}" />
    </Style>

    <Style Selector="Border.workspace-status-message.error">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Danger.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Danger}" />
    </Style>

    <Style Selector="TextBlock.workspace-status-message">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Warning}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="TextBlock.workspace-status-message.success">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Success}" />
    </Style>

    <Style Selector="TextBlock.workspace-status-message.error">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Danger}" />
    </Style>

    <Style Selector="TextBlock.workspace-title">
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    </Style>

    <Style Selector="TextBlock.workspace-caption">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style Selector="TextBlock.field-help">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.field-help.warning-text">
      <Setter Property="Foreground" Value="#B8925E" />
    </Style>

    <Style Selector="ListBox.workspace-list">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.workspace-list ListBoxItem">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Base}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="ListBox.workspace-list ListBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Strong}" />
    </Style>

    <Style Selector="ListBox.workspace-list ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Info.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Accent}" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    </Style>

    <Style Selector="TextBlock.workspace-list-meta">
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="Button.workspace-open-action">
      <Setter Property="Width" Value="32" />
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.workspace-open-action:pointerover">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Accent}" />
    </Style>

    <Style Selector="Button.workspace-open-action:pressed">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Info.Soft}" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Accent}" />
    </Style>

    <Style Selector="Button.workspace-add-action">
      <Setter Property="Width" Value="36" />
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="Regular" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.editor-card">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Border.editor-empty-state">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Code}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="Border.default-icon">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Info.Soft}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Accent}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Full}" />
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
    </Style>

    <Style Selector="TextBlock.path-row-label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <Style Selector="Button.path-icon-action">
      <Setter Property="Width" Value="36" />
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.field-icon-action">
      <Setter Property="Width" Value="32" />
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
      <Setter Property="FontSize" Value="17" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.field-icon-action:pointerover">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    </Style>

    <Style Selector="Button.warning-action">
      <Setter Property="Background" Value="#2B251C" />
      <Setter Property="BorderBrush" Value="#6F5735" />
      <Setter Property="Foreground" Value="#B8925E" />
    </Style>

    <Style Selector="Button.warning-action:pointerover">
      <Setter Property="Background" Value="#32291E" />
      <Setter Property="BorderBrush" Value="#80643D" />
      <Setter Property="Foreground" Value="#C09A64" />
    </Style>

    <Style Selector="ListBox.path-list">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Code}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="MinHeight" Value="120" />
    </Style>

    <Style Selector="ListBox.path-list ListBoxItem">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style Selector="ListBox.path-list ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Info.Soft}" />
    </Style>
  </UserControl.Styles>

  <Border Classes="workspace-shell">
    <Grid x:Name="WorkspaceAdaptiveLayout"
          ColumnDefinitions="360,*"
          ColumnSpacing="4">
      <Border x:Name="WorkspaceListPane"
              Classes="workspace-pane workspace-list-pane"
              IsVisible="{Binding ShowListPane}">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0"
                  Classes="workspace-pane-header">
            <Grid ColumnDefinitions="*,Auto"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="8">
              <TextBlock Grid.Column="0"
                         Classes="workspace-title"
                         Text="Workspaces"
                         VerticalAlignment="Center" />
               <Button Grid.Column="1"
                       Classes="secondary-action compact-action workspace-add-action"
                       Content="+"
                       Command="{Binding CreateWorkspaceCommand}"
                       ToolTip.Tip="New workspace" />
              <TextBlock Classes="workspace-caption"
                         Grid.Row="1"
                         Grid.ColumnSpan="2"
                         Text="Workspaces bind sessions to an execution environment" />
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Classes="workspace-list-body">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <ListBox Classes="workspace-list"
                       ItemsSource="{Binding Workspaces}"
                       SelectedItem="{Binding SelectedWorkspace, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="m:AgentWorkspaceRecord">
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="3"
                          MinWidth="0"
                          Tapped="OnWorkspaceItemTapped">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Grid.Row="1"
                                 Text="{Binding Description}"
                                 Classes="workspace-list-meta"
                                 TextTrimming="CharacterEllipsis" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </ScrollViewer>
          </Border>
        </Grid>
      </Border>

      <Border x:Name="WorkspaceEditorPane"
              Grid.Column="1"
              Classes="workspace-pane"
              IsVisible="{Binding ShowEditorPane}">
        <Grid RowDefinitions="Auto,*,Auto">
          <Border Grid.Row="0"
                  Classes="workspace-pane-header">
            <Grid>
              <StackPanel Spacing="8">
                <TextBlock Classes="workspace-title"
                           Text="Workspace" />
                <TextBlock Classes="workspace-caption"
                           Text="Configure workspace and other settings." />
              </StackPanel>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <Border Classes="workspace-editor-body">
              <StackPanel Spacing="18">
                <StackPanel Spacing="5">
                  <TextBlock Classes="field-label"
                             Text="Display name" />
                  <TextBox x:Name="WorkspaceDisplayNameTextBox"
                           Text="{Binding DisplayName, Mode=TwoWay}"
                           PlaceholderText="Workspace name" />
                </StackPanel>

                <StackPanel Spacing="5">
                  <TextBlock Classes="field-label"
                             Text="Description" />
                  <TextBox Text="{Binding Description, Mode=TwoWay}"
                           PlaceholderText="Description" />
                </StackPanel>

                <StackPanel Spacing="5"
                            IsVisible="{Binding HasExecutionTargetChoices}">
                  <TextBlock Classes="field-label"
                             Text="Execution target" />
                  <ComboBox ItemsSource="{Binding ExecutionTargets}"
                            SelectedItem="{Binding SelectedExecutionTarget, Mode=TwoWay}"
                            HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:ExecutionTargetOption">
                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="3"
                              MinWidth="0">
                          <TextBlock Text="{Binding DisplayName}" />
                          <TextBlock Grid.Row="1"
                                     Text="{Binding Description}"
                                     Classes="field-help" />
                        </Grid>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Spacing="5"
                            IsVisible="{Binding HasNoExecutionTargetChoices}">
                  <TextBlock Classes="field-label"
                             Text="Execution target" />
                  <Border Classes="editor-empty-state">
                    <TextBlock Classes="field-help"
                               Text="No execution packages are installed. Install an execution package to configure shell/file-backed tools. This workspace can still be used for chat." />
                  </Border>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding EditorSections}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AgentEditorSectionViewModel">
                      <Border Classes="editor-card"
                              Margin="0,0,0,12">
                        <StackPanel Spacing="12">
                          <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Sunder.Brush.Foreground.Primary}" />
                            <TextBlock Text="{Binding Description}"
                                       Classes="workspace-caption"
                                       IsVisible="{Binding HasDescription}" />
                          </StackPanel>

                          <ItemsControl ItemsSource="{Binding Fields}">
                            <ItemsControl.DataTemplates>
                              <DataTemplate DataType="vm:AgentEditorTextFieldViewModel"
                                            x:DataType="vm:AgentEditorTextFieldViewModel">
                                <StackPanel Spacing="5"
                                            Margin="0,0,0,12">
                                  <TextBlock Classes="field-label"
                                             Text="{Binding Label}" />
                                  <TextBlock Classes="field-help"
                                             Text="{Binding Description}"
                                             IsVisible="{Binding HasDescription}" />
                                  <TextBox Text="{Binding Value, Mode=TwoWay}" />
                                </StackPanel>
                              </DataTemplate>

                              <DataTemplate DataType="vm:AgentEditorSelectFieldViewModel"
                                            x:DataType="vm:AgentEditorSelectFieldViewModel">
                                <StackPanel Spacing="5"
                                            Margin="0,0,0,12">
                                  <Grid ColumnDefinitions="*,Auto"
                                        ColumnSpacing="8">
                                    <TextBlock Classes="field-label"
                                               Text="{Binding Label}"
                                               VerticalAlignment="Center" />
                                    <ItemsControl Grid.Column="1"
                                                  ItemsSource="{Binding IconActions}"
                                                  IsVisible="{Binding HasIconActions}"
                                                  HorizontalAlignment="Right">
                                      <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                          <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                      </ItemsControl.ItemsPanel>
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AgentEditorActionViewModel">
                                          <Button Classes="field-icon-action"
                                                  Content="{Binding Content}"
                                                  ToolTip.Tip="{Binding Label}"
                                                  Click="OnEditorActionClick" />
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </Grid>
                                  <TextBlock Classes="field-help"
                                              Text="{Binding Description}"
                                              IsVisible="{Binding HasDescription}" />
                                  <Grid ColumnDefinitions="*,Auto"
                                        ColumnSpacing="12"
                                        IsVisible="{Binding HasNoOptions}">
                                    <TextBlock Classes="field-help warning-text"
                                               Text="{Binding Description}"
                                               VerticalAlignment="Top" />
                                    <ItemsControl Grid.Column="1"
                                                  ItemsSource="{Binding TextActions}"
                                                  IsVisible="{Binding ShowEmptyStateActions}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Top">
                                      <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                          <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                      </ItemsControl.ItemsPanel>
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AgentEditorActionViewModel">
                                          <Button Classes="secondary-action compact-action warning-action"
                                                  Content="{Binding Label}"
                                                  Click="OnEditorActionClick" />
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </Grid>
                                  <ComboBox ItemsSource="{Binding Options}"
                                            SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch"
                                            IsVisible="{Binding HasOptions}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:AgentEditorOptionViewModel">
                                        <StackPanel Spacing="2">
                                          <TextBlock Text="{Binding Label}" />
                                          <TextBlock Text="{Binding Description}"
                                                     Classes="field-help"
                                                     IsVisible="{Binding HasDescription}" />
                                        </StackPanel>
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </StackPanel>
                              </DataTemplate>

                              <DataTemplate DataType="vm:AgentEditorPathListFieldViewModel"
                                            x:DataType="vm:AgentEditorPathListFieldViewModel">
                                <StackPanel Spacing="10">
                                  <StackPanel Spacing="4">
                                    <TextBlock Classes="field-label"
                                               Text="{Binding Label}" />
                                    <TextBlock Classes="field-help"
                                               Text="{Binding Description}"
                                               IsVisible="{Binding HasDescription}" />
                                  </StackPanel>

                                  <ListBox Classes="path-list"
                                           ItemsSource="{Binding Items}"
                                           SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                      <DataTemplate x:DataType="vm:AgentEditorPathListItemViewModel">
                                        <Grid ColumnDefinitions="*,Auto"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="8"
                                              RowSpacing="8">
                                          <StackPanel>
                                            <TextBlock Classes="path-row-label"
                                                       Text="{Binding ItemValueLabel}"
                                                       IsVisible="{Binding HasItemValueLabel}" />
                                            <TextBox Text="{Binding Value, Mode=TwoWay}" />
                                          </StackPanel>
                                          <Border Grid.Column="1"
                                                  Classes="default-icon"
                                                  IsVisible="{Binding IsDefault}"
                                                  VerticalAlignment="Bottom"
                                                  ToolTip.Tip="Default working directory">
                                            <TextBlock Text="✓"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource Sunder.Brush.Accent}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                          </Border>
                                          <StackPanel Grid.Row="1"
                                                      Grid.ColumnSpan="2"
                                                      IsVisible="{Binding HasSecondaryValue}">
                                            <TextBlock Classes="path-row-label"
                                                       Text="{Binding SecondaryItemValueLabel}" />
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8">
                                              <TextBox Text="{Binding SecondaryValue, Mode=TwoWay}" />
                                              <Button Grid.Column="1"
                                                      Classes="secondary-action compact-action path-icon-action"
                                                      Content="..."
                                                      Click="OnPickEditorPathItemSecondaryFolderClick"
                                                      IsVisible="{Binding UseSecondaryFolderPicker}"
                                                      ToolTip.Tip="Pick folder" />
                                            </Grid>
                                          </StackPanel>
                                        </Grid>
                                      </DataTemplate>
                                    </ListBox.ItemTemplate>
                                  </ListBox>

                                  <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                        ColumnSpacing="8">
                                    <Button Grid.Column="0"
                                            Classes="secondary-action compact-action"
                                            Content="Set as Default"
                                            IsEnabled="{Binding HasSelectedItem}"
                                            Click="OnSetSelectedEditorPathItemAsDefaultClick" />
                                    <Button Grid.Column="2"
                                            Classes="secondary-action compact-action danger-action path-icon-action"
                                            Content="-"
                                            HorizontalAlignment="Right"
                                            IsEnabled="{Binding HasSelectedItem}"
                                            ToolTip.Tip="Delete selected"
                                            Click="OnDeleteSelectedEditorPathItemClick" />
                                    <Button Grid.Column="3"
                                            Classes="secondary-action compact-action path-icon-action"
                                            Content="+"
                                            HorizontalAlignment="Right"
                                            ToolTip.Tip="{Binding AddItemLabel}"
                                            Click="OnAddEditorPathItemClick" />
                                  </Grid>
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.DataTemplates>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </ScrollViewer>

          <Border Grid.Row="2"
                  Classes="workspace-actions">
            <Grid RowDefinitions="Auto,Auto">
              <Border Grid.Row="0"
                      Classes="workspace-status-message"
                      Classes.success="{Binding IsStatusSuccess}"
                      Classes.warning="{Binding IsStatusWarning}"
                      Classes.error="{Binding IsStatusError}"
                      IsVisible="{Binding HasStatusText}">
                <TextBlock Classes="workspace-status-message"
                           Classes.success="{Binding IsStatusSuccess}"
                           Classes.warning="{Binding IsStatusWarning}"
                           Classes.error="{Binding IsStatusError}"
                           Text="{Binding StatusText}" />
              </Border>

              <Grid Grid.Row="1"
                    ColumnDefinitions="Auto,*,Auto,Auto"
                    ColumnSpacing="12">
                <Button Grid.Column="0"
                        Classes="secondary-action compact-action danger-action"
                        Content="Delete Workspace"
                        Command="{Binding DeleteWorkspaceCommand}" />
                <Button Grid.Column="2"
                        Classes="secondary-action compact-action"
                        Content="Back"
                        Command="{Binding BackToWorkspaceListCommand}"
                        IsVisible="{Binding IsCompactLayout}" />
                <Button Grid.Column="3"
                        Classes="primary-action"
                        Content="Save"
                        Command="{Binding SaveWorkspaceCommand}" />
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
